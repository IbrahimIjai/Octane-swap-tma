// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String     @id @default(cuid())
  isAdmin         Boolean    @default(false)
  isModerator     Boolean    @default(false)
  //socials
  telegramId      String?    @unique
  twitterUsername String?    @unique
  referralCode    String?    @unique
  secretCode      String?    @unique
  referrals       Referral[] @relation("Referrer")
  referredBy      Referral?  @relation("Referred")

  //rewards

  //web3
  address String? @unique // User's wallet address

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Points Stakings
  StakingPositions StakingPosition[]

  //tasks and rewards
  totalRewards    Decimal          @default(0)
  TaskCompletions TaskCompletion[]
  DailyTaskReset  DailyTaskReset?
  Rewards         Reward[]
}

model Task {
  id          String           @id @default(cuid())
  title       String
  points      Decimal
  type        TaskType
  frequency   TaskFrequency
  category    TaskCategory
  actionData  Json?
  completions TaskCompletion[]
  rewards     Reward[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TaskCompletion {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  task      Task       @relation(fields: [taskId], references: [id])
  taskId    String
  status    TaskStatus @default(NOT_STARTED)
  completed DateTime?

  @@unique([userId, taskId])
}

model DailyTaskReset {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  lastReset DateTime
}

model Referral {
  id         String   @id @default(cuid())
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id])
  referrerId String
  referred   User     @relation("Referred", fields: [referredId], references: [id])
  referredId String   @unique
  createdAt  DateTime @default(now())

  @@index([referrerId])
}

model Reward {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  amount    Decimal
  task      Task?      @relation(fields: [taskId], references: [id])
  taskId    String?
  type      RewardType
  claimed   DateTime?
  createdAt DateTime   @default(now())

  @@unique([userId, taskId])
}

model StakingPool {
  id                   String            @id @unique @default(cuid())
  poolName             PoolName
  category             PoolCategory
  totalSupply          Decimal           @default(0)
  rewardRate           Decimal           @default(0) // Rewards per second 
  rewardAmount         Decimal // Total rewards for the pool
  rewardPerTokenStored Decimal
  startTime            DateTime // Pool start time
  endTime              DateTime // Pool end time
  rewardsDuration      Decimal
  lastUpdateTime       DateTime // Last reward calculation timestamp
  periodFinish         Decimal // Matches Synthetix's periodFinish
  positions            StakingPosition[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model StakingPosition {
  id                 String      @id @default(cuid())
  user               User        @relation(fields: [userId], references: [id])
  userId             String
  pool               StakingPool @relation(fields: [poolId], references: [id])
  poolId             String
  amount             Decimal // Staked amount
  rewardPerTokenPaid Decimal     @default(0) // Last reward per token checkpoint
  rewards            Decimal     @default(0) // Accumulated rewards
  lastUpdateTime     DateTime // Last reward calculation timestamp
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([userId, poolId])
}

enum TaskCategory {
  BASED
  ONCHAIN
  PARTNER
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum VerifyMethod {
  AUTOMATIC
  ADMIN_VERIFY
}

enum RewardType {
  WELCOME
  TASK_COMPLETION
  REFERRAL
  DAILY_CHECK_IN
  WEB3_INTERACTION
}

enum TaskType {
  TWITTER_FOLLOW
  TWITTER_QUOTE_RETWEET
  INSTAGRAM_FOLLOW
  YOUTUBE_SUBSCRIBE
  YOUTUBE_WATCH
  TELEGRAM_JOIN
  BOOST_CHANNEL
  TELEGRAM_STORY
  INVITE
  SHARE_POST
  TRADING
  WEB3_INTERACTION
  DAILY_CHECK_IN
}

enum TaskFrequency {
  DAILY
  WEEKLY
  ONE_TIME
}

enum PoolName {
  NITRO_BOOST
  TURBO_CHARGE
  SUPERSONIC_STAKE
  DRAG_RACE_REWARDS
  OCTANE_OVERDRIVE
  FUEL_INJECTION
  PIT_STOP_PROFITS
  VELOCITY_VAULT
  IGNITION
  COMBUSTION_CHAMBER
  HIGH_OCTANE_REWARDS
  FUEL_CELL_FRENZY
  CATALYST_CONVERTER
  THERMAL_THRUST
  POWER_SURGE
  ROCKET_TO_THE_MOON
  DIAMOND_HANDS_VAULT
  HODL_HORSEPOWER
  DEGEN_DRAG_RACE
  MEME_MOMENTUM
  BULL_RUN_BOOSTER
  WHALE_WATCHER_REWARDS
  CRYPTO_COMBUSTION
  MEME_MACHINE_NITRO
  BLOCKCHAIN_BURNOUT
  DEFI_DRIFT
  TOKEN_TURBO_BOOST
  NFT_NITROUS_OXIDE
  SMART_CONTRACT_SPEEDWAY
}

enum PoolCategory {
  SPEED
  COMBUSTION
  CRYPTO
  HYBRID
}
